---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>SpasticKids</h1>
			<p>
				My son has spastic diplegia. This site is where I share what I have learned along the way —
				the games, the setbacks, the small wins, and the thinking behind each decision.
			</p>
			<p>
				I am not a doctor or therapist. I am a parent figuring it out. These posts are my attempt
				to document what worked, what did not, and why — so other parents do not have to start from zero.
			</p>
			<p>
				<a href="/blog">Read the posts</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
